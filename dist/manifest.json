{
  "manifest_version": 3,
  "name": "LM Query Queuer",
  "version": "5.0.0",
  "description": "Queue prompts safely across ChatGPT and fourteen optional AI chat providers.",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Open LM Query Queuer"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "assets/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open-queue-panel": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "MacCtrl+Q"
      },
      "description": "Open LM Query Queuer panel"
    }
  },
  "optional_host_permissions": [
    "https://claude.ai/*",
    "https://www.claude.ai/*",
    "https://chat.qwen.ai/*",
    "https://chat.mistral.ai/*",
    "https://huggingface.co/chat/*",
    "https://grok.com/*",
    "https://www.grok.com/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://chat.z.ai/*",
    "https://z.ai/*",
    "https://www.z.ai/*",
    "https://chat.sakana.ai/*",
    "https://longcat.ai/*",
    "https://www.longcat.ai/*",
    "https://longcat.chat/*",
    "https://www.longcat.chat/*",
    "https://gemini.google.com/*",
    "https://meta.ai/*",
    "https://www.meta.ai/*",
    "https://minimax.io/*",
    "https://www.minimax.io/*",
    "https://agent.minimax.io/*",
    "https://www.agent.minimax.io/*",
    "https://aristotle.science/*",
    "https://www.aristotle.science/*",
    "https://*.aristotle.science/*"
  ]
}
